{
  "$schema": "https://shaderbox.local/tokens.v1.json",
  "description": "Design tokens for shaderbox · v1 · gruvbox-dark theme + wide-screen layout. Every token here maps 1:1 to a CSS variable in prototype.html and a Python constant in theme.py.",

  "colors": {
    "_comment": "Raw palette is gruvbox-dark (morhetz/gruvbox). Role tokens compose on top of raw. Hex format throughout; theme.py converts to (r,g,b,a) floats.",

    "palette": {
      "bg.0h":  "#1d2021",
      "bg.0":   "#282828",
      "bg.0s":  "#32302f",
      "bg.1":   "#3c3836",
      "bg.2":   "#504945",
      "bg.3":   "#665c54",
      "bg.4":   "#7c6f64",
      "gray":   "#928374",
      "fg.4":   "#a89984",
      "fg.3":   "#bdae93",
      "fg.2":   "#d5c4a1",
      "fg.1":   "#ebdbb2",
      "fg.0":   "#fbf1c7",

      "red.n":     "#cc241d",  "red.b":     "#fb4934",
      "green.n":   "#98971a",  "green.b":   "#b8bb26",
      "yellow.n":  "#d79921",  "yellow.b":  "#fabd2f",
      "blue.n":    "#458588",  "blue.b":    "#83a598",
      "purple.n":  "#b16286",  "purple.b":  "#d3869b",
      "aqua.n":    "#689d6a",  "aqua.b":    "#8ec07c",
      "orange.n":  "#d65d0e",  "orange.b":  "#fe8019"
    },

    "role": {
      "_comment": "Semantic roles. Change accent.primary here and the whole UI re-skins. accent.primary is the default yellow; theme.py exposes a switch_accent() helper to swap to aqua/orange/blue.",

      "bg.app":         { "ref": "palette.bg.0",   "_use": "main window background" },
      "bg.surface":     { "ref": "palette.bg.0h",  "_use": "topbar, statusbar, toolbars, sunken regions" },
      "bg.frame":       { "ref": "palette.bg.1",   "_use": "FrameBg — inputs, drags, sliders idle" },
      "bg.frame.hover": { "ref": "palette.bg.2",   "_use": "FrameBgHovered" },
      "bg.frame.active":{ "ref": "palette.bg.3",   "_use": "FrameBgActive" },
      "bg.button":      { "ref": "palette.bg.2",   "_use": "Button idle" },
      "bg.button.hover":{ "ref": "palette.bg.3",   "_use": "ButtonHovered" },
      "bg.button.active":{ "ref": "palette.bg.4",  "_use": "ButtonActive" },
      "bg.popup":       { "ref": "palette.bg.0s",  "_use": "PopupBg — menus, tooltips, modals" },
      "bg.header":      { "ref": "palette.bg.2",   "_use": "Header — collapsing, tree, selectable" },
      "bg.header.hover":{ "ref": "palette.bg.3",   "_use": "HeaderHovered" },
      "bg.header.active":{ "ref": "palette.bg.4",  "_use": "HeaderActive" },

      "border":         { "ref": "palette.bg.2",   "_use": "1 px hairlines" },
      "border.selected":{ "ref": "role.accent.primary", "_use": "selected node/template thumbnail border. WAS green; now follows accent." },

      "fg.primary":     { "ref": "palette.fg.1",   "_use": "primary text" },
      "fg.secondary":   { "ref": "palette.fg.2",   "_use": "secondary text, headings" },
      "fg.muted":       { "ref": "palette.fg.4",   "_use": "muted text" },
      "fg.dim":         { "ref": "palette.gray",   "_use": "dim labels, disabled" },
      "fg.title":       { "ref": "palette.fg.0",   "_use": "modal title, brightest copy" },

      "accent.primary": { "ref": "palette.yellow.b", "_use": "active widget: SliderGrab, CheckMark, NavHighlight, selection stripe" },
      "accent.active":  { "ref": "palette.orange.b", "_use": "while dragging — SliderGrabActive, primary-button pressed" },
      "accent.alpha":   { "rgba": [250, 189, 47, 46], "_use": "slider value-fill behind the grab; custom-draw rect" },

      "state.ok":       { "ref": "palette.aqua.b",   "_use": "shader compiled, auth authed" },
      "state.warn":     { "ref": "palette.yellow.b", "_use": "needs attention, auth unconfigured" },
      "state.error":    { "ref": "palette.red.b",    "_use": "compile error, auth error" },
      "state.info":     { "ref": "palette.blue.b",   "_use": "info banners (exporter config heading)" },

      "scrollbar.bg":   { "ref": "palette.bg.0h" },
      "scrollbar.grab": { "ref": "palette.bg.3" },
      "scrollbar.grab.hover": { "ref": "palette.bg.4" },
      "scrollbar.grab.active":{ "ref": "palette.gray" },

      "syntax.keyword":  { "ref": "palette.red.b",    "_use": "GLSL: if/else/for/return/uniform/in/out" },
      "syntax.type":     { "ref": "palette.yellow.b", "_use": "float/int/vec3/mat4/sampler2D" },
      "syntax.builtin":  { "ref": "palette.green.b",  "_use": "sin/cos/mix/smoothstep/etc" },
      "syntax.number":   { "ref": "palette.purple.b" },
      "syntax.string":   { "ref": "palette.green.b" },
      "syntax.comment":  { "ref": "palette.gray" },
      "syntax.preproc":  { "ref": "palette.aqua.b",   "_use": "#version, #define" },
      "syntax.uniform":  { "ref": "palette.blue.b",   "_use": "identifiers starting with u_" },
      "syntax.identifier":{ "ref": "palette.fg.1" },
      "syntax.operator": { "ref": "palette.fg.3" }
    },

    "accent_swatches": {
      "_comment": "Curated accent options (Tweaks panel). Each entry is {primary, active, alpha-as-rgba255}.",
      "yellow": { "primary": "#fabd2f", "active": "#fe8019", "alpha": [250,189,47,46] },
      "aqua":   { "primary": "#8ec07c", "active": "#689d6a", "alpha": [142,192,124,46] },
      "orange": { "primary": "#fe8019", "active": "#d65d0e", "alpha": [254,128,25,46] },
      "blue":   { "primary": "#83a598", "active": "#458588", "alpha": [131,165,152,56] }
    }
  },

  "spacing": {
    "_comment": "Five-step linear scale. Mapped onto ImGuiStyle WindowPadding, FramePadding, ItemSpacing, ItemInnerSpacing.",
    "xs": 2,
    "sm": 4,
    "md": 8,
    "lg": 16,
    "xl": 24,

    "_imgui_mapping": {
      "WindowPadding":     { "x": "md", "y": "md" },
      "FramePadding":      { "x": 6,    "y": 3 },
      "CellPadding":       { "x": "sm", "y": "xs" },
      "ItemSpacing":       { "x": "md", "y": "sm" },
      "ItemInnerSpacing":  { "x": "sm", "y": "sm" },
      "IndentSpacing":     18,
      "ColumnsMinSpacing": 6
    }
  },

  "density_overrides": {
    "_comment": "When the 'comfortable' density variant is active (Tweaks panel), these spacings replace the defaults.",
    "comfortable": {
      "xs": 3, "sm": 6, "md": 10, "lg": 18, "xl": 28,
      "FramePadding": { "x": 8, "y": 4 },
      "row.height": 26
    }
  },

  "sizes": {
    "_comment": "Pixel sizes the codebase currently hardcodes scattered across files (see pain-points.md §1). All consolidated here.",

    "row.height":          22,
    "row.height.compact":  19,

    "topbar.height":       32,
    "statusbar.height":    24,

    "btn.sm.width":        80,
    "btn.md.width":        120,
    "btn.sm.height":       19,

    "thumb.sm":            90,
    "thumb.md":            110,
    "thumb.lg":            150,

    "image.preview.width": 200,
    "panel.control.min_h": 600,
    "panel.right.min_w":   720,
    "panel.render.max_h":  360,
    "panel.render.min_h":  220,

    "scrollbar.width":     12,
    "grab.min":            10,
    "gutter.width":        48,

    "telegram.thumb.h":    90,
    "telegram.grid.cols":  4,
    "node.creator.cols":   3,

    "modal.min_w":         480,
    "modal.max_w":         720,

    "tooltip.padding.x":   10,
    "tooltip.padding.y":   6
  },

  "rounding": {
    "_comment": "Subtle rounding, not zero, not heavy. Reflects the 'subtle' Tweaks default.",
    "frame":     2,
    "child":     4,
    "window":    4,
    "popup":     4,
    "grab":      2,
    "tab":       2,
    "scrollbar": 6,

    "_variants": {
      "sharp":   { "frame": 0, "child": 0, "window": 0, "popup": 0, "grab": 0, "tab": 0, "scrollbar": 4 },
      "subtle":  { "frame": 2, "child": 4, "window": 4, "popup": 4, "grab": 2, "tab": 2, "scrollbar": 6 },
      "rounded": { "frame": 4, "child": 6, "window": 6, "popup": 6, "grab": 4, "tab": 4, "scrollbar": 8 }
    }
  },

  "borders": {
    "_comment": "ImGuiStyle border sizes. Flat-by-default; modals get a visible border for separation from the dim veil.",
    "window": 1,
    "child":  0,
    "frame":  0,
    "popup":  1,
    "tab":    0
  },

  "alignment": {
    "WindowTitleAlign":    [0.0, 0.5],
    "ButtonTextAlign":     [0.5, 0.5],
    "SelectableTextAlign": [0.0, 0.0]
  },

  "font": {
    "_comment": "JetBrains Mono replaces the current Anonymous Pro. Ship the TTF in resources/fonts/. Cyrillic loads on-demand (Dear ImGui 1.92 BackendFlags_.renderer_has_textures).",
    "family":      "JetBrains Mono",
    "ttf":         "resources/fonts/JetBrainsMono-Regular.ttf",
    "ttf.bold":    "resources/fonts/JetBrainsMono-Bold.ttf",

    "size.small":  12,
    "size.body":   14,
    "size.heading":18,

    "oversample.h": 3,
    "oversample.v": 1
  },

  "misc": {
    "Alpha":           1.0,
    "DisabledAlpha":   0.5,
    "AntiAliasedLines":true,
    "AntiAliasedFill": true
  },

  "tweaks": {
    "_comment": "Tweaks the user can hot-swap from the in-app Tweaks panel without restart. The keys here mirror prototype.html's data-* attributes.",
    "accent":   { "default": "yellow", "options": ["yellow", "aqua", "orange", "blue"] },
    "density":  { "default": "tight",  "options": ["tight", "comfortable"] },
    "rounding": { "default": "subtle", "options": ["sharp", "subtle", "rounded"] },
    "side":     { "default": "left",   "options": ["left", "right"], "_use": "which half holds the GLSL editor" }
  }
}
